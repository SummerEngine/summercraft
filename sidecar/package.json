    "billing-check": "node billing-check.mjs",
    "demo": "bash demo.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "kafkajs": "^2.2.4",
    "pg": "^8.13.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
