{
  "name": "agentcraft-sidecar",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "start": "tsx server.ts",
    "sidecar": "tsx server.ts",
    "dev": "tsx watch server.ts",
    "test": "npm run test:unit && npm run test:integration && npm run test:aiven-smoke",
    "test:unit": "node --import tsx --test \"test/*.test.ts\"",
    "test:integration": "node test/integration.mjs",
    "test:aiven-smoke": "tsx aiven-smoke.ts",
    "test:kafka-smoke": "tsx kafka-smoke.ts",
    "test:multiplayer-smoke": "tsx multiplayer-smoke.ts",
