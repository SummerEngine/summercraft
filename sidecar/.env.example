# SummerCraft sidecar — example env. COPY this to `.env` and fill in your values:
#     cp .env.example .env
# `.env` is gitignored (your real keys never get committed). This `.env.example` is the TEMPLATE —
# keep it empty, never paste real keys here. A blank value just means that feature stays off (no errors).

# ─── Postgres — the shared world's memory (optional; solo play needs no cloud) ───
# Aiven Console → your Postgres service → "Service URI". Looks like:
#   postgres://avnadmin:PASSWORD@pg-xxxx.aivencloud.com:NNNNN/defaultdb?sslmode=require
AIVEN_PG_URI=
# Only needed for verify-full TLS: path to Aiven's ca.pem (Console → service → CA certificate).
AIVEN_PG_CA=

# ─── Kafka — the activity stream (optional) ───
AIVEN_KAFKA_BROKERS=
AIVEN_KAFKA_USERNAME=
AIVEN_KAFKA_PASSWORD=
AIVEN_KAFKA_CA=

# ─── Aiven MCP / Ada the data-operator (optional) ───
# A personal token (Aiven Console → User → Tokens). Lets Ada operate your infra via the MCP.
AIVEN_TOKEN=
AIVEN_PROJECT=
# Advanced: only set this to run Ada against the HOSTED Aiven MCP (all missions). The bundled
# `npm run demo` sets its own loopback shim URL, so leave this blank for the standard demo.
# AGENTCRAFT_AIVEN_MCP_URL=https://mcp.aiven.live/mcp

# ─── ElevenLabs voice (optional) ───
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# ─── Local Docker (alternative to Aiven, for testing) ───
# Uncomment to test against local Docker instead of Aiven:
# AIVEN_PG_URI=postgres://postgres:summercraft@localhost:5433/summercraft
# AIVEN_KAFKA_BROKERS=localhost:9092
